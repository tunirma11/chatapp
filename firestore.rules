rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isRoomMember(roomId) {
      return hasUserProfile()
        && userDoc().roomId == roomId
        && userDoc().username is string;
    }

    function myUsername() {
      return userDoc().username;
    }

    // Admin panel uses anonymous auth without a users/{uid} chat profile.
    // Room wipe needs the same auth level as rooms/{id} delete.
    function canWipeRoomData() {
      return request.auth != null;
    }

    function validMemberData() {
      return request.resource.data.id is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.passwordHash is string
        && request.resource.data.passwordHash.size() > 0;
    }

    function messageType() {
      return request.resource.data.type == null
        ? 'text'
        : request.resource.data.type;
    }

    function validImageUrl() {
      return request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.size() > 0
        && (
          (request.resource.data.imageUrl.matches('https://firebasestorage.googleapis.com/.*')
            && request.resource.data.imageUrl.size() <= 2048)
          || (request.resource.data.imageUrl.matches('data:image/.*')
            && request.resource.data.imageUrl.size() <= 750000)
        );
    }

    function validGalleryImageCreate(roomId) {
      return isRoomMember(roomId)
        && request.auth.uid == request.resource.data.addedByUid
        && request.resource.data.addedBy is string
        && request.resource.data.addedBy == myUsername()
        && (request.resource.data.addedBy == 'm1' || request.resource.data.addedBy == 'm2')
        && validImageUrl();
    }

    function validGalleryOpenCreate(roomId) {
      return isRoomMember(roomId)
        && myUsername() == 'm2'
        && request.resource.data.openedBy == 'm2'
        && request.resource.data.keys().hasOnly(['openedBy', 'openedAt', 'clientAt'])
        && (request.resource.data.clientAt is int
          || request.resource.data.clientAt is float);
    }

    function validMessageCreate(roomId) {
      let t = messageType();
      let hasText = !('text' in request.resource.data)
        || (request.resource.data.text is string
          && request.resource.data.text.size() <= 1000);
      return isRoomMember(roomId)
        && request.auth.uid == request.resource.data.senderUid
        && request.resource.data.senderId is string
        && request.resource.data.senderName is string
        && (t == 'text' || t == 'link' || t == 'image' || t == 'system')
        && hasText
        && (t != 'image' || validImageUrl())
        && (t != 'link' || (
          request.resource.data.linkUrl is string
          && request.resource.data.linkUrl.size() > 0
        ));
    }

    function validMessageUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly([
          'readBy', 'read', 'deliveredBy', 'deletedAt', 'deletedBy', 'hiddenFor',
          'imageUrl', 'imageThumbUrl', 'imageStripped', 'imageStrippedAt',
          'linkUrl', 'linkPreview',
          'reactions', 'pinned', 'pinnedAt', 'editedAt', 'text'
        ]);
    }

    match /config/admin {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.memberCount == 0
        && request.resource.data.status == "active";
      allow update: if request.auth != null;
      allow delete: if canWipeRoomData();

      match /members/{username} {
        allow read: if true;
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.memberCount < 2
          && validMemberData()
          && request.resource.data.id == username;
        allow update: if request.auth != null;
        allow delete: if canWipeRoomData();
      }

      match /presence/{username} {
        allow read: if isRoomMember(roomId) || canWipeRoomData();
        allow create, update: if isRoomMember(roomId) && username == myUsername();
        allow delete: if canWipeRoomData()
          || (isRoomMember(roomId) && username == myUsername());
      }

      match /meta/{docId} {
        allow read: if isRoomMember(roomId) || canWipeRoomData();
        allow create, update: if isRoomMember(roomId);
        allow delete: if canWipeRoomData() || isRoomMember(roomId);
      }

      match /messages/{msgId} {
        // Admin room wipe must list+delete; members keep chat access
        allow read: if isRoomMember(roomId) || canWipeRoomData();
        // Chat hard-remove: m1 only. Room wipe: admin or auth user not in this room as m2.
        allow delete: if request.auth != null && (
          !hasUserProfile()
          || userDoc().roomId != roomId
          || myUsername() == "m1"
        );
        allow create: if validMessageCreate(roomId);
        allow update: if isRoomMember(roomId) && validMessageUpdate();
      }

      match /gallery/{imageId} {
        allow read: if isRoomMember(roomId) || canWipeRoomData();
        allow create: if validGalleryImageCreate(roomId);
        allow update: if false;
        allow delete: if canWipeRoomData()
          || (isRoomMember(roomId) && (
            myUsername() == "m1"
            || resource.data.addedBy == myUsername()
          ));
      }

      // Stealth: only m1 can read open events; only m2 can create them.
      match /galleryOpens/{eventId} {
        allow read: if canWipeRoomData()
          || (isRoomMember(roomId) && myUsername() == "m1");
        allow create: if validGalleryOpenCreate(roomId);
        allow update: if false;
        allow delete: if canWipeRoomData()
          || (isRoomMember(roomId) && myUsername() == "m1");
      }
    }

    match /users/{uid} {
      allow read: if request.auth != null
        && (
          request.auth.uid == uid
          || (hasUserProfile() && resource.data.roomId == userDoc().roomId)
          || canWipeRoomData()
        );
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.roomId is string
        && request.resource.data.username is string;
      allow update: if request.auth != null && request.auth.uid == uid;
      // Room wipe deletes user profiles for that room
      allow delete: if canWipeRoomData();
    }
  }
}
