rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRoomMember(roomId) {
      return request.auth != null
        && userDoc().roomId == roomId
        && userDoc().username is string;
    }

    function validMemberData() {
      return request.resource.data.id is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.passwordHash is string
        && request.resource.data.passwordHash.size() > 0;
    }

    match /config/admin {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.memberCount == 0
        && request.resource.data.status == "active";
      allow update: if request.auth != null;
      allow delete: if false;

      match /members/{username} {
        allow read: if true;
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.memberCount < 2
          && validMemberData()
          && request.resource.data.id == username;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /messages/{msgId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId)
          && request.auth.uid == request.resource.data.senderUid
          && request.resource.data.senderId is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow update, delete: if false;
      }
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.roomId is string
        && request.resource.data.username is string;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }
  }
}
